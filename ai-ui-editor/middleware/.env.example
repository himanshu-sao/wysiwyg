# NVIDIA NIM API Key (required for real AI responses)
# Get your key from: https://build.nvidia.com/
# Free tier available with generous limits for development
NVIDIA_API_KEY=your_api_key_here

# Optional: Model to use (default: meta/llama-3.1-70b-instruct)
# Available models on NVIDIA NIM:
#   - meta/llama-3.1-70b-instruct (default, best for code)
#   - meta/llama-3.1-8b-instruct
#   - mistralai/mistral-large-2-instruct
#   - nvidia/llama-3.1-nemotron-70b-instruct
#   - google/gemma-2-9b-it
#   - microsoft/phi-3.5-moe-instruct
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Optional: Middleware server configuration
PORT=3000
HOST=0.0.0.0

# Optional: Enable debug logging
DEBUG=true
